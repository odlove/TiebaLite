<resources>
    <style name="Widget" />

    <style name="Widget.Button.Flat.Dense" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:padding">6dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:elevation">0dp</item>
        <item name="buttonTextColor">@color/sem_state_active</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Button" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:padding">6dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:elevation">0dp</item>
        <item name="buttonBackgroundTint">@color/sem_state_active</item>
        <item name="buttonTextColor">@color/sem_content_on_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>
</resources>
